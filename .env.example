# =============================================================================
# NCRC member map — environment template (no real secrets; safe to commit)
# Copy to `.env` (gitignored) and fill in your project values.
#
# Mapping:
#   • GitHub Actions    → repository "Secrets and variables"
#   • Cloud Run Job     → job env / Secret Manager
#   • Cloud Run Service → service env / Secret Manager
#
# Local browser test (needs a filled .env):  ./scripts/dev-local.sh
#   → http://127.0.0.1:8765/  — then: git checkout -- js/config.local.js (stub has no secrets; see README.md)
# =============================================================================

# -----------------------------------------------------------------------------
# Google Cloud — project & service account
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
MEMBER_MAP_SA_ID=member-map
MEMBER_MAP_SA_EMAIL=
GCP_PROJECT=

# -----------------------------------------------------------------------------
# Workload Identity Federation (GitHub Actions → GCP)
# -----------------------------------------------------------------------------
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

WIF_POOL_ID=github-actions-pool
WIF_PROVIDER_ID=github-oidc

# Full resource name from: gcloud iam workload-identity-pools providers describe PROVIDER_ID \
#   --location=global --workload-identity-pool=POOL_ID --format='value(name)'
WIF_PROVIDER=

WIF_SERVICE_ACCOUNT=

# -----------------------------------------------------------------------------
# GitHub Actions — .github/workflows/weekly-members-export.yml
# -----------------------------------------------------------------------------
GCP_REGION=us-east1
GCP_RUN_JOB_NAME=ncrc-members-export

# -----------------------------------------------------------------------------
# Cloud Run Job — BigQuery → Mapbox tileset
# -----------------------------------------------------------------------------
BQ_TABLE=
MAPBOX_ACCESS_TOKEN=
MAPBOX_TILESET=
MAPBOX_UPLOAD_NAME=ncrc-members-weekly
# Local only: set to 1 to write data/state_counts.json from BigQuery without Mapbox upload (needs gcloud auth application-default login).
# SKIP_MAPBOX_UPLOAD=1

# -----------------------------------------------------------------------------
# Mapbox — public / browser (Cloud Run Service)
# -----------------------------------------------------------------------------
MAPBOX_PUBLIC_ACCESS_TOKEN=
# Mapbox Studio style URL — set only in private .env / Cloud Run (do not commit)
MAPBOX_STYLE_URL=
# Members tileset (circles). Often mapbox://USERNAME.TILESET_ID — must match layer your job updates if using weekly export.
MAPBOX_TILESET_URL=
# State boundaries tileset (fill + outline + feature-state). Separate from members.
STATE_BOUNDARIES_TILESET_URL=
# source-layer in state tileset (Mapbox Studio → Tilesets → layer name)
STATE_BOUNDARIES_SOURCE_LAYER=State_Shoreline-al2frv
# source-layer in members tileset (circle layers). Must match Mapbox tileset vector layer — same as MAPBOX_UPLOAD_NAME from the export job by default.
MEMBERS_SOURCE_LAYER=ncrc-members-weekly
# Per-state choropleth totals (same JSON shape as job output: {"NY":42,...}).
# Production: deploy ./scripts/deploy-cloud-run.sh — it builds ncrc-members-counts (BigQuery SQL on each request).
# Set this to that service URL, e.g. https://ncrc-members-counts-xxxxx.run.app/
# Leave empty to fall back to /data/state_counts.json from the last export job run.
MEMBERS_STATE_COUNTS_URL=
# Optional: refetch counts and repaint the choropleth every N seconds (0 = only on page load). Use with MEMBERS_STATE_COUNTS_URL pointing at your API.
MEMBERS_STATE_COUNTS_REFRESH_SEC=0
# Optional: override Cloud Run service name for the counts API (default: ncrc-members-counts).
# CLOUD_RUN_COUNTS_SERVICE_NAME=
# Counts API only: in-memory BigQuery result cache TTL in seconds (0 = no cache). Deploy script passes this to ncrc-members-counts.
# STATE_COUNTS_CACHE_TTL_SEC=300

# -----------------------------------------------------------------------------
# Secret Manager (names used by scripts/deploy-cloud-run.sh)
# -----------------------------------------------------------------------------
# mapbox-members-upload-token  → job env MAPBOX_ACCESS_TOKEN
# mapbox-members-public-token    → service env MAPBOX_PUBLIC_ACCESS_TOKEN
#
# gcloud secrets create SECRET_NAME --data-file=- --project=YOUR_PROJECT_ID --replication-policy=automatic
